{
  "name": "优雅古典",
  "description": "衬线体，双线边框，古典气息",
  "styles": {
    "wrapper": {
      "background_color": "{{background}}",
      "padding": "20px"
    },
    "h1": {
      "font_size": "30px",
      "font_weight": "700",
      "color": "{{primary}}",
      "line_height": "1.3",
      "letter_spacing": "-0.01em",
      "padding": "12px 0",
      "border_top": "2px solid {{primary}}",
      "border_bottom": "1px solid {{primary}}",
      "margin_top": "36px",
      "margin_bottom": "20px",
      "text_align": "center"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "{{accent}}",
      "line_height": "1.5",
      "text_transform": "uppercase",
      "letter_spacing": "0.1em",
      "padding": "10px 0",
      "border_bottom": "1px dashed {{accent}}",
      "margin_top": "32px",
      "margin_bottom": "18px",
      "text_align": "center"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "{{accent}}",
      "line_height": "1.4",
      "padding": "6px 0 6px 16px",
      "border_left": "3px solid {{accent}}",
      "margin_top": "26px",
      "margin_bottom": "14px"
    },
    "p": {
      "font_size": "16px",
      "color": "#333333",
      "line_height": "1.9",
      "margin_top": "0",
      "margin_bottom": "18px",
      "text_align": "justify"
    },
    "blockquote": {
      "border_top": "1px solid {{table_border}}",
      "border_bottom": "1px solid {{table_border}}",
      "background": "{{blockquote_bg}}",
      "padding": "18px 24px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_style": "italic"
    },
    "strong": {
      "font_weight": "700",
      "color": "{{accent}}"
    },
    "em": {
      "font_style": "italic",
      "color": "{{primary}}"
    },
    "a": {
      "color": "{{accent}}",
      "text_decoration": "none",
      "border_bottom": "1px solid {{accent}}"
    },
    "hr": {
      "margin_top": "40px",
      "margin_bottom": "40px",
      "height": "1px",
      "background": "linear-gradient(90deg, transparent 0%, {{accent}} 30%, {{accent}} 70%, transparent 100%)",
      "border": "none",
      "width": "60%",
      "margin_left": "auto",
      "margin_right": "auto"
    },
    "code": {
      "background": "{{code_bg}}",
      "padding": "3px 6px",
      "border_radius": "3px",
      "font_size": "13px",
      "color": "{{accent}}",
      "font_family": "Georgia, serif"
    },
    "code_block": {
      "background": "{{code_bg}}",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "border": "1px solid {{table_border}}"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 14px",
      "background": "{{accent_light}}44",
      "border_bottom": "1px solid {{table_border}}"
    },
    "pre": {
      "background": "{{code_bg}}",
      "padding": "18px",
      "font_size": "13px",
      "line_height": "1.6",
      "font_family": "Georgia, serif"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "{{accent}}",
      "font_size": "13px",
      "font_family": "Georgia, serif"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "14px",
      "font_family": "Georgia, serif"
    },
    "th": {
      "background": "{{blockquote_bg}}",
      "padding": "12px 14px",
      "text_align": "center",
      "font_weight": "600",
      "border_bottom": "2px solid {{accent}}",
      "font_family": "Georgia, serif"
    },
    "td": {
      "padding": "10px 14px",
      "border_bottom": "1px solid {{table_border}}",
      "text_align": "center"
    },
    "list_item_bullet": {
      "color": "{{accent}}",
      "margin_right": "10px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "20px",
      "height": "20px",
      "background": "{{accent}}",
      "color": "#fff",
      "border_radius": "50%",
      "font_size": "11px",
      "font_weight": "bold",
      "margin_right": "10px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.8",
      "font_family": "Georgia, serif"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "callout": {
      "background": "{{blockquote_bg}}",
      "border_top": "1px solid {{table_border}}",
      "border_bottom": "1px solid {{table_border}}",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "8px",
      "font_size": "14px",
      "letter_spacing": "0.05em"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.7",
      "font_style": "italic"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "border_left": "2px solid {{accent}}",
      "padding": "0 0 0 10px",
      "margin_top": "22px",
      "margin_bottom": "10px"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#555555",
      "margin_top": "18px",
      "margin_bottom": "8px"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#888888",
      "margin_top": "14px",
      "margin_bottom": "6px"
    },
    "img_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "img": {
      "max_width": "100%",
      "display": "block"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "14px",
      "border_top": "1px solid {{table_border}}"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "10px",
      "letter_spacing": "0.05em"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#666666",
      "margin_bottom": "6px",
      "line_height": "1.5"
    },
    "footnote_sup": {
      "font_size": "11px",
      "color": "{{accent}}",
      "vertical_align": "super"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_style": "italic"
    }
  }
}
