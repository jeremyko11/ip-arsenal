{
  "name": "粗体醒目",
  "description": "大字重，宽边距，强对比",
  "styles": {
    "wrapper": {
      "background_color": "{{background}}",
      "padding": "24px"
    },
    "h1": {
      "font_size": "32px",
      "font_weight": "800",
      "color": "#fff",
      "line_height": "1.2",
      "letter_spacing": "-0.02em",
      "padding": "20px 24px",
      "background": "{{accent}}",
      "border_radius": "16px",
      "margin_top": "24px",
      "margin_bottom": "20px",
      "box_shadow": "0 8px 24px {{accent}}40"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#fff",
      "line_height": "1.3",
      "padding": "14px 20px",
      "background": "{{accent_light}}",
      "border_radius": "10px",
      "margin_top": "28px",
      "margin_bottom": "16px",
      "box_shadow": "0 4px 12px {{accent}}20"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "700",
      "color": "{{accent}}",
      "line_height": "1.4",
      "padding": "10px 16px",
      "border": "2px solid {{accent}}",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "14px"
    },
    "p": {
      "font_size": "16px",
      "color": "#222222",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "18px",
      "font_weight": "400"
    },
    "blockquote": {
      "border_left": "6px solid {{accent}}",
      "background": "{{blockquote_bg}}",
      "padding": "18px 24px",
      "border_radius": "0 12px 12px 0",
      "margin_top": "22px",
      "margin_bottom": "22px",
      "box_shadow": "0 4px 16px {{accent}}15"
    },
    "strong": {
      "font_weight": "800",
      "color": "{{accent}}"
    },
    "em": {
      "font_style": "italic",
      "color": "{{primary}}"
    },
    "a": {
      "color": "{{accent}}",
      "text_decoration": "none",
      "font_weight": "600",
      "border_bottom": "2px solid {{accent}}"
    },
    "hr": {
      "margin_top": "40px",
      "margin_bottom": "40px",
      "height": "4px",
      "background": "{{accent}}",
      "border": "none",
      "border_radius": "2px",
      "width": "80px"
    },
    "code": {
      "background": "{{accent_light}}33",
      "padding": "4px 10px",
      "border_radius": "6px",
      "font_size": "14px",
      "color": "{{accent}}",
      "font_weight": "600"
    },
    "code_block": {
      "background": "{{code_bg}}",
      "border_radius": "14px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "border": "2px solid {{accent_light}}"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "42px",
      "padding": "0 16px",
      "background": "{{accent}}"
    },
    "pre": {
      "background": "{{code_bg}}",
      "padding": "20px",
      "font_size": "14px",
      "line_height": "1.6"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "{{accent}}",
      "font_size": "14px"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "12px",
      "overflow": "hidden",
      "border": "2px solid {{accent_light}}"
    },
    "th": {
      "background": "{{accent}}",
      "padding": "14px 16px",
      "text_align": "left",
      "font_weight": "700",
      "color": "#fff"
    },
    "td": {
      "padding": "12px 16px",
      "border_bottom": "1px solid {{table_border}}"
    },
    "list_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "26px",
      "height": "26px",
      "background": "{{accent}}",
      "color": "#fff",
      "border_radius": "8px",
      "font_size": "14px",
      "font_weight": "bold",
      "margin_right": "12px"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "26px",
      "height": "26px",
      "background": "{{accent}}",
      "color": "#fff",
      "border_radius": "8px",
      "font_size": "14px",
      "font_weight": "bold",
      "margin_right": "12px"
    },
    "list_item_text": {
      "font_size": "16px",
      "color": "#222222",
      "line_height": "1.7",
      "font_weight": "500"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "12px",
      "align_items": "center"
    },
    "callout": {
      "background": "{{accent}}",
      "padding": "18px 24px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "border_radius": "14px",
      "box_shadow": "0 6px 20px {{accent}}30"
    },
    "callout_title": {
      "font_weight": "800",
      "color": "#fff",
      "margin_bottom": "10px",
      "font_size": "16px"
    },
    "callout_content": {
      "font_size": "15px",
      "color": "#fff",
      "line_height": "1.6",
      "opacity": "0.95"
    },
    "h4": {
      "font_size": "18px",
      "font_weight": "700",
      "color": "{{accent}}",
      "padding": "10px 16px",
      "background": "{{accent_light}}22",
      "border_radius": "8px",
      "margin_top": "22px",
      "margin_bottom": "12px"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "700",
      "color": "#444444",
      "margin_top": "18px",
      "margin_bottom": "10px"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "700",
      "color": "#666666",
      "margin_top": "14px",
      "margin_bottom": "8px"
    },
    "img_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "img": {
      "max_width": "100%",
      "display": "block",
      "border_radius": "12px"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "2px solid {{table_border}}"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "700",
      "color": "{{accent}}",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "13px",
      "color": "#555555",
      "margin_bottom": "8px",
      "line_height": "1.5"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "{{accent}}",
      "vertical_align": "super",
      "font_weight": "bold"
    },
    "blockquote_p": {
      "font_size": "16px",
      "color": "#222222",
      "line_height": "1.7",
      "margin_bottom": "0"
    }
  }
}
