{
  "name": "渐变卡片",
  "description": "渐变背景块，立体感强",
  "styles": {
    "wrapper": {
      "background_color": "{{background}}",
      "padding": "16px"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "700",
      "color": "{{primary}}",
      "line_height": "1.3",
      "letter_spacing": "-0.015em",
      "padding": "14px 16px",
      "border_left": "5px solid {{accent}}",
      "border_radius": "10px",
      "background": "linear-gradient(135deg, {{accent_light}}22 0%, {{accent}}11 100%)",
      "margin_top": "32px",
      "margin_bottom": "18px",
      "box_shadow": "0 4px 12px {{accent}}22"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "700",
      "color": "{{accent}}",
      "line_height": "1.4",
      "padding": "10px 14px",
      "border_radius": "8px",
      "background": "linear-gradient(90deg, {{accent}}15 0%, transparent 100%)",
      "border_bottom": "2px solid {{accent}}",
      "margin_top": "28px",
      "margin_bottom": "16px"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "{{accent}}",
      "line_height": "1.45",
      "padding": "6px 0 6px 12px",
      "border_left": "3px solid {{accent}}",
      "margin_top": "24px",
      "margin_bottom": "14px"
    },
    "p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "16px"
    },
    "blockquote": {
      "border_left": "4px solid {{accent}}",
      "background": "linear-gradient(135deg, {{blockquote_bg}} 0%, {{accent_light}}22 100%)",
      "padding": "16px 20px",
      "border_radius": "0 12px 12px 0",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "box_shadow": "0 2px 8px {{accent}}15"
    },
    "strong": {
      "font_weight": "700",
      "color": "{{accent}}",
      "background": "linear-gradient(180deg, transparent 60%, {{accent_light}}40 60%)",
      "padding": "0 2px"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "{{accent}}",
      "text_decoration": "none",
      "border_bottom": "1px solid {{accent}}"
    },
    "hr": {
      "margin_top": "36px",
      "margin_bottom": "36px",
      "height": "2px",
      "background": "linear-gradient(90deg, transparent 0%, {{accent}} 50%, transparent 100%)",
      "border": "none"
    },
    "code": {
      "background": "{{code_bg}}",
      "padding": "3px 8px",
      "border_radius": "4px",
      "font_size": "13px",
      "color": "{{accent}}"
    },
    "code_block": {
      "background": "{{code_bg}}",
      "border_radius": "10px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "overflow": "hidden",
      "box_shadow": "0 4px 12px {{accent}}15"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "linear-gradient(90deg, {{accent}} 0%, {{accent_light}} 100%)"
    },
    "pre": {
      "background": "{{code_bg}}",
      "padding": "16px",
      "font_size": "13px",
      "line_height": "1.5"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "{{accent}}",
      "font_size": "13px"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "linear-gradient(135deg, {{accent_light}}44 0%, {{accent_light}}22 100%)",
      "padding": "12px 14px",
      "text_align": "left",
      "font_weight": "600",
      "border_bottom": "2px solid {{accent}}"
    },
    "td": {
      "padding": "10px 14px",
      "border_bottom": "1px solid {{table_border}}"
    },
    "list_item_bullet": {
      "color": "{{accent}}",
      "margin_right": "10px",
      "font_weight": "bold",
      "font_size": "16px"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "background": "linear-gradient(135deg, {{accent}} 0%, {{accent_light}} 100%)",
      "color": "#fff",
      "border_radius": "50%",
      "font_size": "12px",
      "font_weight": "bold",
      "margin_right": "10px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.7"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "10px",
      "align_items": "flex-start"
    },
    "callout": {
      "background": "linear-gradient(135deg, {{accent_light}}22 0%, {{accent}}11 100%)",
      "border_left": "4px solid {{accent}}",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 10px 10px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.6"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "border_left": "3px solid {{accent}}",
      "padding": "0 0 0 10px",
      "margin_top": "20px",
      "margin_bottom": "10px"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#555555",
      "margin_top": "16px",
      "margin_bottom": "8px"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#888888",
      "margin_top": "12px",
      "margin_bottom": "6px"
    },
    "img_wrapper": {
      "background": "#fff",
      "border_radius": "8px",
      "padding": "4px",
      "margin_top": "12px",
      "margin_bottom": "12px",
      "box-shadow": "0 2px 8px rgba(0,0,0,0.08)"
    },
    "img": {
      "max_width": "100%",
      "display": "block",
      "border_radius": "6px"
    },
    "footnote_section": {
      "margin_top": "28px",
      "padding_top": "14px",
      "border_top": "1px dashed {{table_border}}"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "10px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#666666",
      "margin_bottom": "6px",
      "line_height": "1.5"
    },
    "footnote_sup": {
      "font_size": "11px",
      "color": "{{accent}}",
      "vertical_align": "super"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.7",
      "margin_bottom": "0"
    }
  }
}
