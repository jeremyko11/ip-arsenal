{
  "name": "现代卡片",
  "description": "卡片式布局，方块感强",
  "styles": {
    "wrapper": {
      "background_color": "{{background}}",
      "padding": "16px"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "700",
      "color": "#fff",
      "line_height": "1.3",
      "letter_spacing": "-0.01em",
      "padding": "16px 20px",
      "background": "{{accent}}",
      "border_radius": "12px",
      "margin_top": "28px",
      "margin_bottom": "18px",
      "box_shadow": "0 4px 16px {{accent}}40"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "{{accent}}",
      "line_height": "1.4",
      "padding": "10px 16px",
      "background": "{{accent_light}}33",
      "border_radius": "8px",
      "border_left": "4px solid {{accent}}",
      "margin_top": "26px",
      "margin_bottom": "14px"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "{{accent}}",
      "line_height": "1.4",
      "padding": "8px 12px",
      "background": "{{accent_light}}22",
      "border_radius": "6px",
      "margin_top": "22px",
      "margin_bottom": "12px"
    },
    "p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "16px"
    },
    "blockquote": {
      "border": "1px solid {{accent_light}}",
      "background": "{{blockquote_bg}}",
      "padding": "16px 20px",
      "border_radius": "12px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "box_shadow": "0 2px 8px {{accent}}10"
    },
    "strong": {
      "font_weight": "700",
      "color": "{{accent}}"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "{{accent}}",
      "text_decoration": "none",
      "font_weight": "500"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "3px",
      "background": "linear-gradient(90deg, {{accent}} 0%, {{accent_light}} 50%, {{accent}} 100%)",
      "border": "none",
      "border_radius": "2px"
    },
    "code": {
      "background": "{{accent_light}}33",
      "padding": "3px 8px",
      "border_radius": "4px",
      "font_size": "13px",
      "color": "{{accent}}",
      "font_weight": "500"
    },
    "code_block": {
      "background": "{{code_bg}}",
      "border_radius": "12px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "overflow": "hidden",
      "border": "1px solid {{accent_light}}"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "38px",
      "padding": "0 14px",
      "background": "{{accent}}"
    },
    "pre": {
      "background": "{{code_bg}}",
      "padding": "16px",
      "font_size": "13px",
      "line_height": "1.5"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "{{accent}}",
      "font_size": "13px"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "10px",
      "overflow": "hidden",
      "border": "1px solid {{table_border}}"
    },
    "th": {
      "background": "{{accent_light}}44",
      "padding": "12px 14px",
      "text_align": "left",
      "font_weight": "600",
      "border_bottom": "2px solid {{accent_light}}"
    },
    "td": {
      "padding": "10px 14px",
      "border_bottom": "1px solid {{table_border}}"
    },
    "list_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "background": "{{accent}}",
      "color": "#fff",
      "border_radius": "6px",
      "font_size": "12px",
      "font_weight": "bold",
      "margin_right": "10px"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "background": "{{accent}}",
      "color": "#fff",
      "border_radius": "6px",
      "font_size": "12px",
      "font_weight": "bold",
      "margin_right": "10px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.7",
      "flex": "1"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "10px",
      "align_items": "center"
    },
    "callout": {
      "background": "{{accent_light}}22",
      "border": "1px solid {{accent_light}}",
      "border_left": "4px solid {{accent}}",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 10px 10px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.6"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "background": "{{accent_light}}22",
      "padding": "8px 12px",
      "border_radius": "6px",
      "margin_top": "18px",
      "margin_bottom": "10px"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#555555",
      "margin_top": "14px",
      "margin_bottom": "8px"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#888888",
      "margin_top": "12px",
      "margin_bottom": "6px"
    },
    "img_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "img": {
      "max_width": "100%",
      "display": "block",
      "border_radius": "8px"
    },
    "footnote_section": {
      "margin_top": "28px",
      "padding_top": "14px",
      "border_top": "1px solid {{table_border}}"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "10px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#666666",
      "margin_bottom": "6px",
      "line_height": "1.5"
    },
    "footnote_sup": {
      "font_size": "11px",
      "color": "{{accent}}",
      "vertical_align": "super"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.7",
      "margin_bottom": "0"
    }
  }
}
