{
  "name": "简约线条",
  "description": "无装饰，左对齐，干净利落",
  "styles": {
    "wrapper": {
      "background_color": "{{background}}",
      "padding": "16px"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "700",
      "color": "{{primary}}",
      "line_height": "1.3",
      "letter_spacing": "-0.02em",
      "padding": "8px 0 8px 0",
      "border_left": "4px solid {{accent}}",
      "margin_top": "32px",
      "margin_bottom": "16px"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "{{primary}}",
      "line_height": "1.4",
      "padding": "6px 0 6px 0",
      "border_left": "3px solid {{accent}}",
      "margin_top": "28px",
      "margin_bottom": "14px"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "{{accent}}",
      "line_height": "1.45",
      "padding": "4px 0 4px 0",
      "margin_top": "24px",
      "margin_bottom": "12px"
    },
    "p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "16px"
    },
    "blockquote": {
      "border_left": "3px solid {{accent}}",
      "background": "{{blockquote_bg}}",
      "padding": "12px 16px",
      "margin_top": "20px",
      "margin_bottom": "20px"
    },
    "strong": {
      "font_weight": "700",
      "color": "{{accent}}"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "{{accent}}",
      "text_decoration": "none"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "1px",
      "background": "{{accent}}",
      "border": "none"
    },
    "code": {
      "background": "{{code_bg}}",
      "padding": "2px 6px",
      "border_radius": "3px",
      "font_size": "13px",
      "color": "{{accent}}"
    },
    "code_block": {
      "background": "{{code_bg}}",
      "border_radius": "6px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 12px",
      "background": "{{accent_light}}"
    },
    "pre": {
      "background": "{{code_bg}}",
      "padding": "16px",
      "font_size": "13px",
      "line_height": "1.5"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "{{accent}}",
      "font_size": "13px"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "font_size": "14px"
    },
    "th": {
      "background": "{{accent_light}}",
      "padding": "10px 14px",
      "text_align": "left",
      "font_weight": "600",
      "border_bottom": "2px solid {{accent}}"
    },
    "td": {
      "padding": "10px 14px",
      "border_bottom": "1px solid {{table_border}}"
    },
    "list_item_bullet": {
      "color": "{{accent}}",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "20px",
      "height": "20px",
      "background": "{{accent}}",
      "color": "#fff",
      "border_radius": "50%",
      "font_size": "12px",
      "font_weight": "bold",
      "margin_right": "8px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.7"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "callout": {
      "background": "{{blockquote_bg}}",
      "border_left": "3px solid {{accent}}",
      "padding": "14px",
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "6px",
      "font_size": "14px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.6"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "{{primary}}",
      "margin_top": "20px",
      "margin_bottom": "8px"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#555555",
      "margin_top": "16px",
      "margin_bottom": "6px"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#888888",
      "margin_top": "12px",
      "margin_bottom": "6px"
    },
    "img_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "img": {
      "max_width": "100%",
      "display": "block"
    },
    "footnote_section": {
      "margin_top": "28px",
      "padding_top": "14px",
      "border_top": "1px solid {{table_border}}"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "{{accent}}",
      "margin_bottom": "10px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#666666",
      "margin_bottom": "6px",
      "line_height": "1.5"
    },
    "footnote_sup": {
      "font_size": "11px",
      "color": "{{accent}}",
      "vertical_align": "super"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.7",
      "margin_bottom": "0"
    }
  }
}
